  "legal": {
    "termsTitle": "Gebruiksvoorwaarden",
    "privacyTitle": "Privacybeleid",
    "lastUpdated": "Laatst bijgewerkt",
    "termsAcceptance": "Aanvaarding van voorwaarden",
    "termsAcceptanceText": "Door Re-Bali te bezoeken en te gebruiken, gaat u akkoord met deze Gebruiksvoorwaarden. Als u niet akkoord gaat, gebruik onze platform dan niet. Deze voorwaarden gelden voor alle gebruikers, kopers en verkopers.",
